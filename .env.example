# ─── realtime-flow 配置模板 ─────────────────────────
# 使用方法：
#   cp .env.example .env
#   vi .env  # 填写实际值
#
# .env 文件已在 .gitignore 中排除，不会提交到 git

# ─── Cloudflare Tunnel 配置 ─────────────────────────
# 你的域名（Cloudflare 托管）
TUNNEL_DOMAIN=example.com
# 子域名（外网访问地址）
TUNNEL_SUBDOMAIN=stock.example.com
# Tunnel 名称（任意，用于标识）
TUNNEL_NAME=realtime-flow

# ─── 本地服务端口 ───────────────────────────────────
LOCAL_PORT=8899

# ─── 访问认证（Cookie 认证） ────────────────────────
# 留空则不启用认证（仅本地访问时可不启用）
AUTH_USER=admin
AUTH_PASS=change_your_password_here
